# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL Database (Neon)
# Для Neon используйте connection string в формате:
# postgresql://username:password@ep-xxx.region.aws.neon.tech/database_name?sslmode=require
# Или раздельные параметры:
DB_HOST=ep-xxx.region.aws.neon.tech
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_neon_password_here
DB_PORT=5432

# Альтернатива: можно использовать DATABASE_URL для Neon
# DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/database_name?sslmode=require

# USDT Wallet Address (владельца)
OWNER_WALLET_ADDRESS=your_usdt_trc20_wallet_address

# Exchange Rate API (опционально, бот использует множественные источники)
EXCHANGE_RATE_API=https://rapira.net/exchange/USDT_RUB

# Proxy settings (опционально, если нужен для доступа к Telegram API)
# PROXY_URL=http://proxy.server:port
# PROXY_URL=socks5://proxy.server:port

# Render Port (автоматически устанавливается Render)
PORT=8080
